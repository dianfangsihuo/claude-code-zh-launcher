# Copy this file to .env.local or use the launcher UI.
# Do not put real API keys in GitHub issues, screenshots, or commits.

CLAUDE_PROVIDER=openai
ANTHROPIC_BASE_URL=http://127.0.0.1:3456
ANTHROPIC_AUTH_TOKEN=local-launcher-proxy
ANTHROPIC_MODEL=deepseek-v4-flash

PROVIDER_BASE_URL=https://api.deepseek.com
PROVIDER_API_KEY=replace_with_your_api_key
DEEPSEEK_API_KEY=replace_with_your_api_key
PROVIDER_MODE=openai
PROVIDER_REASONING=auto
